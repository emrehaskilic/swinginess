+  const winRate = Number(performance.winRate || 0);
+  const maxDrawdown = Math.max(0, Number(performance.maxDrawdown || 0));
+  const maxDrawdownPercent = startBalance > 0 ? (maxDrawdown / startBalance) * 100 : 0;
+  const currentDrawdown = Math.max(0, -netPnl);
+  const currentDrawdownPercent = startBalance > 0 ? (currentDrawdown / startBalance) * 100 : 0;
