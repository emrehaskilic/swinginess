# =============================================================================
# Trading Bot Configuration - Environment Variables
# =============================================================================
# 
# This file contains all environment variables for the trading bot.
# Copy this file to .env and fill in your values.
#
# SAFETY NOTES:
# - NEVER commit .env files with real credentials to version control
# - Trading is disabled by default - set TRADING_ENABLED=true to enable
# - Paper trading is enabled by default - set PAPER_TRADING=false for live trading
# - Testnet is enabled by default - set EXCHANGE_TESTNET=false for live exchange
#
# CRITICAL: All configuration is validated at boot time. Invalid configuration
# will cause the application to fail fast with clear error messages.
# =============================================================================

# =============================================================================
# Node Environment
# =============================================================================
NODE_ENV=development
PORT=3000

# =============================================================================
# Trading Configuration
# =============================================================================

# Maximum acceptable latency in milliseconds (default: 500)
# Range: 100-5000
LATENCY_THRESHOLD=500

# Flash crash detection threshold as percentage (default: 5)
# Range: 1-50
FLASH_CRASH_THRESHOLD=5

# Maximum drawdown percentage before halt (default: 10)
# Range: 1-100
MAX_DRAWDOWN=10

# Minimum consensus size for multi-source validation (default: 3)
# Range: 1-10
QUORUM_SIZE=3

# Minimum confidence threshold 0-1 (default: 0.7 = 70%)
# Range: 0.1-1.0
CONFIDENCE_THRESHOLD=0.7

# Maximum position size as percentage of portfolio (default: 20)
# Range: 1-100
MAX_POSITION_SIZE=20

# Stop loss percentage (default: 2)
# Range: 0.1-50
STOP_LOSS_PERCENT=2

# Take profit percentage (default: 5)
# Range: 0.1-100
TAKE_PROFIT_PERCENT=5

# Maximum number of concurrent trades (default: 5)
# Range: 1-100
MAX_CONCURRENT_TRADES=5

# Enable trading (default: false)
# SAFETY: Set to true only when you are ready to trade
TRADING_ENABLED=false

# Paper trading mode (default: true)
# SAFETY: Set to false for live trading with real money
PAPER_TRADING=true

# =============================================================================
# System Configuration
# =============================================================================

# Memory usage threshold percentage 0-100 (default: 80)
# Range: 50-99
MEMORY_THRESHOLD=80

# WebSocket timeout in milliseconds (default: 30000)
# Range: 5000-300000
WS_TIMEOUT=30000

# Health check interval in milliseconds (default: 30000)
# Range: 5000-300000
HEALTH_CHECK_INTERVAL=30000

# Graceful shutdown timeout in milliseconds (default: 10000)
# Range: 1000-60000
GRACEFUL_SHUTDOWN_TIMEOUT=10000

# Log level (default: info)
# Options: debug, info, warn, error
LOG_LEVEL=info

# Maximum log file size in MB (default: 100)
# Range: 10-1000
MAX_LOG_FILE_SIZE=100

# Number of log files to keep (default: 5)
# Range: 1-20
LOG_FILE_COUNT=5

# Enable metrics endpoint (default: true)
ENABLE_METRICS=true

# =============================================================================
# Exchange Configuration
# =============================================================================

# Exchange identifier (default: binance)
# Supported: binance, coinbase, kraken, etc.
EXCHANGE_ID=binance

# Exchange API key
# REQUIRED when TRADING_ENABLED=true
EXCHANGE_API_KEY=your_api_key_here

# Exchange API secret
# REQUIRED when TRADING_ENABLED=true
EXCHANGE_API_SECRET=your_api_secret_here

# Testnet mode (default: true)
# SAFETY: Set to false for live exchange
EXCHANGE_TESTNET=true

# Rate limit requests per second (default: 10)
# Range: 1-100
EXCHANGE_RATE_LIMIT=10

# Enable rate limiting (default: true)
EXCHANGE_ENABLE_RATE_LIMIT=true

# =============================================================================
# Risk Management Configuration
# =============================================================================

# Daily loss limit as percentage (default: 5)
# Range: 0.1-100
DAILY_LOSS_LIMIT=5

# Maximum trades per day (default: 50)
# Range: 1-1000
MAX_TRADES_PER_DAY=50

# Cooldown period after loss in milliseconds (default: 60000)
# Range: 0-3600000
COOLDOWN_AFTER_LOSS=60000

# Require confirmation for large trades (default: true)
CONFIRM_LARGE_TRADES=true

# Large trade threshold in USD (default: 10000)
# Range: 100-1000000
LARGE_TRADE_THRESHOLD=10000

# Circuit breaker enabled (default: true)
CIRCUIT_BREAKER_ENABLED=true

# Circuit breaker threshold - consecutive losses (default: 3)
# Range: 1-20
CIRCUIT_BREAKER_THRESHOLD=3

# =============================================================================
# Safety Checklist
# =============================================================================
# 
# Before enabling live trading, verify:
# 
# [ ] TRADING_ENABLED is set to true
# [ ] PAPER_TRADING is set to false (if you want live trading)
# [ ] EXCHANGE_TESTNET is set to false (if you want live exchange)
# [ ] EXCHANGE_API_KEY is set to your live API key
# [ ] EXCHANGE_API_SECRET is set to your live API secret
# [ ] MAX_DRAWDOWN is set to an acceptable level
# [ ] DAILY_LOSS_LIMIT is set to an acceptable level
# [ ] You have tested thoroughly in paper trading mode
# [ ] You understand the risks involved
#
# WARNING: Live trading involves real financial risk. You could lose money.
# Only trade with funds you can afford to lose.
# =============================================================================
