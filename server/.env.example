# Execution connector
API_KEY_SECRET=local-dev-api-key
EXECUTION_ENABLED=false
BINANCE_TESTNET_API_KEY=
BINANCE_TESTNET_API_SECRET=
BINANCE_TESTNET_REST_BASE=https://testnet.binancefuture.com
BINANCE_TESTNET_USER_WS_BASE=wss://stream.binancefuture.com
BINANCE_TESTNET_MARKET_WS_BASE=wss://stream.binancefuture.com
BINANCE_RECV_WINDOW_MS=5000
DEFAULT_MARGIN_TYPE=CROSSED
DEFAULT_SYMBOL_LEVERAGE=20

# Gate configuration
ENABLE_GATE_V2=false
MAX_NETWORK_LATENCY_MS=2500
MAX_SPREAD_PCT=0.08
MIN_OBI_DEEP=0.05

# Strategy configuration
# Shared 1m bootstrap backfill limit (single fetch path)
BOOTSTRAP_1M_LIMIT=500
# Set high default - user can adjust via UI, will be clamped by actual wallet balance
STARTING_MARGIN_USDT=5000
MIN_MARGIN_USDT=5
RAMP_STEP_PCT=10
RAMP_DECAY_PCT=20
RAMP_MAX_MULT=5
MAX_LEVERAGE=100
HARD_STOP_LOSS_PCT=1.0
LIQUIDATION_EMERGENCY_MARGIN_RATIO=0.30
TAKER_FEE_BPS=4
PROFIT_LOCK_BUFFER_BPS=2
COOLDOWN_MIN_MS=2000
COOLDOWN_MAX_MS=20000
LOCK_TRIGGER_R=0.8
MAX_DD_FROM_PEAK_R=0.25
ADD_MIN_UPNL_R=0.3
ADD_ONLY_IF_TREND_CONFIRMED=true
ADD_ONLY_IF_POSITIVE=true
TREND_CONFIRM_TICKS=2
TREND_REVERSAL_CONFIRM_TICKS=3
MTF_ENABLED=true
MTF_MIN_CONSENSUS=0.7
MTF_OPPOSITE_EXIT_CONSENSUS=0.8
MTF_DEADBAND=0.1
MTF_WEIGHT_M1=1.0
MTF_WEIGHT_M3=1.0
MTF_WEIGHT_M5=1.2
MTF_WEIGHT_M15=1.4
MTF_NORM_M1=1
MTF_NORM_M3=1
MTF_NORM_M5=500
MTF_NORM_M15=1000
TRAILING_STOP_ENABLED=true
TRAILING_STOP_ACTIVATION_R=0.8
TRAILING_STOP_RATIO=0.3
TRAILING_STOP_MIN_DD_R=0.2
REGIME_TREND_PROFIT_LOCK_TRIGGER_R=1.0
REGIME_TREND_SCALE_IN_LEVELS=3
REGIME_TREND_STOP_DISTANCE_PCT=0.5
REGIME_MR_PROFIT_LOCK_TRIGGER_R=0.4
REGIME_MR_SCALE_IN_LEVELS=1
REGIME_MR_STOP_DISTANCE_PCT=0.3
REGIME_EV_PROFIT_LOCK_TRIGGER_R=0.6
REGIME_EV_SCALE_IN_LEVELS=2
REGIME_EV_STOP_DISTANCE_PCT=0.8
ORCHESTRATOR_ENGINE_MODE=PLAN
MAX_EXPOSURE_MULTIPLIER=2.0
BLOCK_LOSER_REALIZE=true
DRAWDOWN_REDUCE_ENABLED=false
DRAWDOWN_REDUCE_PCT=8
MAX_MARGIN_USAGE_PCT=0.85
MAX_POSITION_NOTIONAL_USDT=10000
DAILY_LOSS_LOCK_PCT=0.05
DUST_MIN_NOTIONAL_USDT=5
DUST_MIN_QTY=0.000001
MIN_REDUCE_NOTIONAL_USDT=15
STRAT_ENTRY_CANCEL_STREAK_TRIGGER=2
STRAT_ENTRY_CANCEL_BASE_COOLDOWN_MS=15000
STRAT_ENTRY_CANCEL_MAX_COOLDOWN_MS=120000
STRAT_ENTRY_CANCEL_BACKOFF_MULT=1.75
STRAT_ENTRY_POST_ONLY=false
MICROPRICE_OFFSET_BPS=1.5
LIMIT_TTL_MS=4000
BASE_ENTRY_PCT=0.35

# Orderbook reliability - make LIVE state easier to achieve
LIVE_GOOD_SEQUENCE_MIN=10
LIVE_SNAPSHOT_FRESH_MS=30000
LIVE_DESYNC_RATE_10S_MAX=100

# Symbol concurrency - allow multiple pairs to be active simultaneously
SYMBOL_CONCURRENCY=10

# Logger backpressure
LOGGER_QUEUE_LIMIT=5000
LOGGER_DROP_HALT_THRESHOLD=200

# Notifications (optional, keep these secret)
TELEGRAM_WEBHOOK_URL=
DISCORD_WEBHOOK_URL=

# Institutional risk engine (FAZ 2)
RISK_ENGINE_ENABLED=true
RISK_ENGINE_DEFAULT_EQUITY_USDT=5000
RISK_REDUCED_POSITION_MULTIPLIER=0.5
RISK_MAX_POSITION_NOTIONAL_USDT=10000
RISK_MAX_TOTAL_NOTIONAL_USDT=20000
RISK_MAX_POSITION_QTY=10
RISK_MAX_LEVERAGE=20
RISK_POSITION_WARNING_THRESHOLD=0.8
RISK_DAILY_LOSS_WARNING_RATIO=0.07
RISK_DAILY_LOSS_LIMIT_RATIO=0.1
RISK_MAX_DRAWDOWN_RATIO=0.15
RISK_DRAWDOWN_CHECK_INTERVAL_MS=5000
RISK_DRAWDOWN_AUTO_HALT=true
RISK_MAX_CONSECUTIVE_LOSSES=5
RISK_CONSECUTIVE_LOSS_WINDOW_MS=3600000
RISK_REDUCED_AFTER_CONSECUTIVE_LOSSES=3
RISK_CONSECUTIVE_LOSS_MULTIPLIER=0.5
RISK_MAX_PARTIAL_FILL_RATE=0.3
RISK_MAX_REJECT_RATE=0.2
RISK_EXECUTION_TIMEOUT_MS=10000
RISK_EXECUTION_WINDOW_MS=300000
RISK_EXECUTION_AUTO_HALT=true
RISK_LATENCY_SPIKE_MS=5000
RISK_VOLATILITY_SPIKE_RATIO=0.05
RISK_DISCONNECT_TIMEOUT_MS=30000
RISK_PRICE_WINDOW_MS=60000
RISK_AUTO_CLOSE_POSITIONS=true
